@model Note


 <div class="container shadow p-5">
    <div class="row pb-2">
        <h2>Edit Note</h2>
    </div>

    <form method="post" asp-action="Edit"  asp-controller="NoteBook">
        <div asp-validation-summary="All"></div>

        <div class="form-row">
            <div class="form-group col-md-6">
                <label asp-for="Title">Note Title</label>
                <input type="text" class="form-control mb-3" asp-for="Title" placeholder="Enter Title" required>
                <span asp-validation-for="Title" class=" alert-danger"></span>
            </div>
            <div class="form-group col-md-6">
                <label asp-for="Description">Description</label>
                <input type="text" class="form-control mb-3" asp-for="Description" placeholder="Enter Description">
                <span asp-validation-for="Description" class=" alert-danger"></span>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group col-md-6">
                <label asp-for="CreatedDate">CreatedDate</label>
                <input type="text" class="form-control mb-3" asp-for="CreatedDate" placeholder="CreatedDate">
                <span asp-validation-for="CreatedDate" class=" alert-danger"></span>
            </div>
        </div>


        <button type="submit" class="btn btn-lg btn-primary p-2"><i class="bi bi-file-plus-fill"></i>Update</button>
        <a asp-controller="NoteBook" asp-action="Index" class="btn btn-lg btn-warning p-2">Back To List</a>
    </form>

</div> 


@*//for front end validations*@

section Scripts {
    @{
        <partial name="_ValidationScriptsPartial" />
    }
} 