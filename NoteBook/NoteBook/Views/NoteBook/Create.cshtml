@model Note


<div class="container shadow p-5">
    <div class="row pb-2">
        <h2>Add Note</h2>
    </div>

    <form method="post">
        <div asp-validation-summary="All"></div>

        <div class="form-row">
            <div class="form-group col-md-6">
                <label asp-for="Title">Note Title</label>
                <input type="text" class="form-control mb-3" asp-for="Title" value = "My plan" required>
                <span asp-validation-for="Title" class=" alert-danger"></span>
            </div>
            <div class="form-group col-md-6">
                <label asp-for="Description">Description</label>
                <input type="text" class="form-control mb-3" asp-for="Description" value="Without description">
                <span asp-validation-for="Description" class=" alert-danger"></span>
            </div>
        </div>
                    <div class="form-group col-md-6">
                <input asp-for="CreatedDate" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm:ss")"/>
            </div>
        <div class="form-row">
            <div class="form-group col-md-6">
                <label asp-for="DueDate">DueDate</label>
                <input type="text" class="form-control mb-3" asp-for="DueDate" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm:ss")">
                <span asp-validation-for="DueDate" class=" alert-danger"></span>
            </div>
            <div class="form-group col-md-6">
  <label for="mySelect">Choose hash tag</label>
<select id="mySelect" name="mySelect">
  <option value="option1">#робота</option>
  <option value="option2">#відпочинок</option>
  <option value="option3">#навчання</option>
  <option value="option3">#спорт</option>
  <option value="option3">#покупки</option>
  <option value="option3">#домашнісправи</option>
  <option value="option3">#зустрічі</option>
  <option value="option3">#поїздки</option>
  <option value="option3">#хобі</option>
  <option value="option3">#проект</option>
  <option value="option3">#терміновісправи</option>
  <option value="option3">#планування</option>
  <option value="option3">#особистіснийріст</option>
  <option value="option3">#здоров’я</option>
  <option value="option3">#фінанси</option>
</select>
            </div>
        </div>

        <button type="submit" class="btn btn-lg btn-primary p-2"><i class="bi bi-file-plus-fill"></i>Save</button>
        <a asp-controller="NoteBook" asp-action="Index" class="btn btn-lg btn-warning p-2">Show All Notes</a>
    </form>

</div>


@*//for front end validations*@

@section Scripts {
    @{
        <partial name="_ValidationScriptsPartial" />
    }
}